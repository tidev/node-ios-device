{
  "name": "node-ios-device",
  "version": "7.0.0",
  "description": "Simple library for detecting and installing apps on iOS devices",
  "keywords": [
    "device",
    "devices",
    "install",
    "ios",
    "ipad",
    "iphone",
    "mobile",
    "mobiledevice"
  ],
  "homepage": "https://github.com/tidev/node-ios-device",
  "bugs": "https://github.com/tidev/node-ios-device/issues",
  "license": "Apache-2.0",
  "author": "TiDev, Inc. <npm@tidev.io>",
  "repository": "https://github.com/tidev/node-ios-device",
  "bin": "./bin/node-ios-device",
  "files": [
    "dist",
    "prebuilds",
    "scripts/copy-framework.js",
    "src/*.{cpp,h}",
    "binding.gyp",
    "media"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "pnpm build:bundle && pnpm rebuild",
    "build:bundle": "rimraf dist && tsdown -c tsdown.config.ts",
    "build:prebuilds": "prebuildify --napi=true --strip",
    "check": "pnpm type-check && pnpm lint && pnpm fmt:check",
    "clean": "node-gyp clean",
    "coverage": "vitest --pool=forks --coverage",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "prepublishOnly": "pnpm build:bundle && pnpm build:prebuilds",
    "rebuild": "node-gyp rebuild",
    "test": "vitest --allowOnly --pool=forks",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "node-gyp-build": "4.8.4",
    "snooplogg": "8.0.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "lefthook": "2.1.9",
    "node-gyp": "13.0.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "prebuildify": "6.0.1",
    "rimraf": "6.1.3",
    "tsdown": "0.22.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "gypfile": true
}
